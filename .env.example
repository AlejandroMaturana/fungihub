# ── LOCAL (desarrollo) ──────────────────────────────────────────
# WIFI CREDENTIALS (firmware)
WIFI_SSID_1=YourSSID1
WIFI_PASSWORD_1=YourPassword1
WIFI_SSID_2=YourSSID2
WIFI_PASSWORD_2=YourPassword2

# THINGSPEAK (firmware only — backend reads per-device from DB)
# TS_API_KEY=YourTSAPIKey
TS_HOST=api.thingspeak.com
TS_PORT=80

DEVICE_ID=mush2_001

# LOCALHOST DB
DB_USER     =postgres
DB_HOST     =localhost
DB_NAME     =namedb
DB_PASSWORD =passworddb
DB_PORT     =5432
DATABASE_URL=postgresql://postgres:passworddb@localhost:5432/namedb

# JWT
JWT_SECRET =secretPassword123

# MQTT (opcional — por defecto test.mosquitto.org:1883)
# MQTT_BROKER=mqtt://tu-broker.local:1883
# MQTT_BROKER_FALLBACK=mqtt://broker.hivemq.com:1883

# ── RAILWAY (producción) ────────────────────────────────────────
# En Railway, estas variables se configuran en el Dashboard.
# Railway inyecta automáticamente DATABASE_URL al agregar un
# PostgreSQL addon. Las demás se agregan manualmente en:
#   Settings > Variables
#
# NODE_ENV=production
# PORT=3797               (Railway asigna automáticamente)
# DATABASE_URL=           (viene del addon PostgreSQL)
# JWT_SECRET=             (generar con: openssl rand -hex 32)
# CORS_ORIGIN=https://tu-app.up.railway.app
# MQTT_BROKER=            (opcional)
# TELEGRAM_BOT_TOKEN=     (opcional)
# TELEGRAM_BOT_USERNAME=  (opcional)
